{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "buildCommand": "vite build",
    "outputDirectory": "dist/public",
    "installCommand": "npm install --legacy-peer-deps",
    "framework": null,
    "functions": {
          "api/index.ts": {
                  "memory": 1024,
                  "maxDuration": 30
          }
    },
    "rewrites": [
          { "source": "/api/(.*)", "destination": "/api" },
          { "source": "/((?!api/).*)", "destination": "/index.html" }
    ]
}
