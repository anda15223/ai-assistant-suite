{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "buildCommand": "pnpm run build",
    "outputDirectory": "dist/public",
    "installCommand": "pnpm install",
    "framework": null,
    "functions": {
          "api/index.js": {
                  "memory": 1024,
                  "maxDuration": 30
          }
    },
    "rewrites": [
          { "source": "/api/(.*)", "destination": "/api" },
          { "source": "/((?!api/).*)", "destination": "/index.html" }
    ]
}
